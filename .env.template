# ── VM Migration Estimator – Platform Credentials ──────────────────────────
# Copy this file to .env and fill in your values.
# The server auto-connects all platforms with non-empty credentials on startup.
#
#   cp .env.template .env
#
# .env is gitignored and never committed.
# ---------------------------------------------------------------------------

# ── VMware vCenter ──────────────────────────────────────────────────────────
VMWARE_ENDPOINT=https://vcenter.example.com
VMWARE_USERNAME=administrator@vsphere.local
VMWARE_PASSWORD=

# ── OpenShift / Kubernetes ──────────────────────────────────────────────────
# Token: oc whoami --show-token
OPENSHIFT_ENDPOINT=https://api.cluster.example.com:6443
OPENSHIFT_TOKEN=

# ── Pure Storage FlashArray ─────────────────────────────────────────────────
# API token from FlashArray GUI → System → Users → API Tokens
FLASHARRAY_ENDPOINT=flasharray.example.com
FLASHARRAY_API_TOKEN=
